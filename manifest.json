{
  "manifest_version": 3,
  "name": "SocialCat",
  "description": "Make X easier: enter-to-send, smart replies, retweet collapse, and time-based greetings.",
  "version": "1.1.0",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://web.social-dog.net/*",
    "https://cdn.syndication.twimg.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://web.social-dog.net/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "socialdog-injected.js"
      ],
      "matches": [
        "https://web.social-dog.net/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_popup": "popup.html",
    "default_title": "SocialCat"
  },
  "options_page": "options.html"
}
